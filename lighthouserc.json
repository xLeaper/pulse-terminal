{
  "ci": {
    "collect": {
      "url": [
        "http://localhost:3000/",
        "http://localhost:3000/watchlist?role=Data%20Analyst&skills=Python,SQL,Excel",
        "http://localhost:3000/skill/python",
        "http://localhost:3000/recruiter?skills=Python,SQL,AWS",
        "http://localhost:3000/sources"
      ],
      "numberOfRuns": 1,
      "settings": {
        "preset": "desktop",
        "throttlingMethod": "simulate",
        "skipAudits": ["uses-http2", "is-on-https", "redirects-http"]
      }
    },
    "assert": {
      "assertions": {
        "categories:accessibility": ["error", { "minScore": 0.9 }],
        "categories:best-practices": ["warn", { "minScore": 0.9 }],
        "categories:seo": ["warn", { "minScore": 0.9 }],
        "categories:performance": ["warn", { "minScore": 0.7 }],
        "color-contrast": "error",
        "image-alt": "error",
        "label": "error",
        "link-name": "error",
        "button-name": "error",
        "html-has-lang": "error",
        "meta-viewport": "error",
        "document-title": "error"
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
